{
  "info": {
    "name": "Sakura Saki MVC API",
    "description": "Postman collection for testing Sakura Saki endpoints. Note: Because this is a Spring MVC application using Thymeleaf, requests expect `x-www-form-urlencoded` data instead of JSON. You must first run the 'Auth - Login' request to receive a JSESSIONID cookie, which Postman will automatically save and use for subsequent authenticated requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "firstName", "value": "Test", "type": "text"},
                {"key": "lastName", "value": "User", "type": "text"},
                {"key": "username", "value": "testuser", "type": "text"},
                {"key": "email", "value": "test@example.com", "type": "text"},
                {"key": "phone", "value": "0712345678", "type": "text"},
                {"key": "password", "value": "Password@123", "type": "text"}
              ]
            },
            "url": {
              "raw": "{{base_url}}/register",
              "host": ["{{base_url}}"],
              "path": ["register"]
            }
          }
        },
        {
          "name": "Login (Sets Cookie)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "username", "value": "admin", "type": "text"},
                {"key": "password", "value": "Admin@123", "type": "text"}
              ]
            },
            "url": {
              "raw": "{{base_url}}/do-login",
              "host": ["{{base_url}}"],
              "path": ["do-login"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/logout",
              "host": ["{{base_url}}"],
              "path": ["logout"]
            }
          }
        }
      ]
    },
    {
